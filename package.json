{
  "name": "timer",
  "version": "1.0.0",
  "description": "Timer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "dist": "electron-builder --mac dmg zip"
  },
  "build": {
    "appId": "com.caldvs.timer",
    "productName": "Timer",
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "icon": "icon.icns",
      "category": "public.app-category.productivity",
      "identity": null
    },
    "dmg": {
      "title": "Timer ${version}",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "tray-icon.png",
      "package.json"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  }
}
